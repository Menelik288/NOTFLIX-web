# Frontend-safe environment variables (exposed to client via VITE_ prefix)
# Copy this file to .env and fill in your values

# Supabase configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API server URL (for local development)
VITE_API_BASE=http://localhost:3001

# In production, set VITE_API_BASE to your production API URL or leave empty to use Edge Functions